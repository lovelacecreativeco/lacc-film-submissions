# .env  (never commit this file — it is in .gitignore)

# Path on the host machine where uploaded films will be stored
UPLOAD_HOST_PATH=/path/to/your/drop/folder

# Password required to submit an upload (leave blank for open uploads)
UPLOAD_PASS=changeme

# Host port the app is exposed on (default: 3035)
APP_PORT=3035

# User and group ID the app process runs as inside the container.
# Should match the owner of UPLOAD_HOST_PATH on the host.
# TrueNAS SCALE apps user is typically 568.
PUID=568
PGID=568
